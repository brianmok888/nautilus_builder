# Nautilus Builder — Environment Configuration
# Copy to .env and customize for your deployment.
# NEVER commit real secrets to version control.

# ── API Authentication ──────────────────────────────────────────
# Token for API authentication (CHANGE IN PRODUCTION)
BUILDER_API_TOKEN=change-me-in-production
BUILDER_ENV=local

# ── Application Environment ─────────────────────────────────────
# Set to "production" to enforce production safety checks
# APP_ENV=production

# ── Database (Builder-Owned) ──────────────────────────────────────
# Builder owns its own database. It must NOT write to runtime/trading DBs.
# When BUILDER_DATABASE_URL is set, all state persists in Postgres.
# When unset, in-memory mode is used (state lost on restart).
POSTGRES_USER=builder
POSTGRES_PASSWORD=builder_dev
POSTGRES_DB=nautilus_builder
# BUILDER_DATABASE_URL=postgresql://builder:builder_dev@localhost:5432/nautilus_builder
#
# DO NOT point this at a runtime/trading database:
#   ND_RUNTIME_DATABASE_URL — not for Builder
#   NAUTILUS_DAEDALUS_DATABASE_URL — not for Builder
#   TRADING_DATABASE_URL — not for Builder

# ── CORS ────────────────────────────────────────────────────────
# Comma-separated origins allowed for CORS
# BUILDER_CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ── Demo Data ───────────────────────────────────────────────────
# Seed demo strategies on first startup (1=yes, 0=no)
BUILDER_SEED_DEMO_STRATEGIES=1

# ── Fixture Fallback ───────────────────────────────────────────
# Allow fixture fallback for workflow results (DO NOT SET IN PRODUCTION)
# BUILDER_ALLOW_FIXTURE_FALLBACK=0

# ── Rate Limiting ──────────────────────────────────────────────
# Requests per minute per IP (0 = unlimited)
# BUILDER_RATE_LIMIT=60

# ── Frontend (docker-compose) ──────────────────────────────────
# API base URL for server-side rendering (internal Docker network)
# BUILDER_API_BASE_URL=http://api:8000
# Public API base URL for client-side (empty for same-origin)
# NEXT_PUBLIC_API_BASE_URL=
# Browser-exposed Builder API tokens are intentionally unsupported.
# Do not add NEXT_PUBLIC_BUILDER_API_TOKEN.
# Use server-side auth/session/proxy patterns instead.
BUILDER_ENV=local

# ── AI Provider (optional) ─────────────────────────────────────
# OpenAI-compatible endpoint for advisory AI drafting
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o

# ── Venue Credentials ──────────────────────────────────────────
# Venue credentials go in .env.execution.local (gitignored).
# NEVER put real exchange credentials in this file.
# See .env.execution.local for venue-specific credential format:
#   {VENUE}_API_KEY=your-key
#   {VENUE}_API_SECRET=your-secret
#   {VENUE}_PASSPHRASE=your-passphrase  # (if required)
