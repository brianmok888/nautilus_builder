# Nautilus Builder — Dev Demo Environment
# Copy to .env and customize before running the demo.

# Builder-owned Postgres database (separate from Nautilus-Daedalus runtime DB).
BUILDER_DATABASE_URL=postgresql://builder:builder_dev@localhost:5432/nautilus_builder

# API auth token for local demo.
# Replace before shared/staging demos.
BUILDER_ENV=local
BUILDER_API_TOKEN=replace-with-strong-demo-token

# Local artifact storage for demo.
BUILDER_ARTIFACT_ROOT=./var/builder_artifacts

# API base URL for the local web frontend.
# Keep the browser-facing API URL empty so same-origin requests go through
# the Next middleware; the middleware injects BUILDER_API_TOKEN only in local mode.
NEXT_PUBLIC_API_BASE_URL=
BUILDER_API_BASE_URL=http://localhost:8000

# IMPORTANT: Do not add the builder API token as a NEXT_PUBLIC_ variable.
# It must not be exposed to the browser bundle.
