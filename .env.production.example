# Production Environment Configuration
# ALL values must be explicitly set. No defaults are provided.

# ── Required ────────────────────────────────────────────────────

# Must be "production"
BUILDER_ENV=production

# Strong API token (≥32 chars, not dev-token/test-token/changeme)
BUILDER_API_TOKEN=

# PostgreSQL connection string
BUILDER_DATABASE_URL=postgresql://builder:CHANGE_ME@db-host:5432/nautilus_builder

# CORS origins (comma-separated, no wildcard)
BUILDER_CORS_ORIGINS=https://builder.example.com

# ── Rate Limiting ───────────────────────────────────────────────

# Backend: "memory" (dev only) or "redis" (required for production)
BUILDER_RATE_LIMIT_BACKEND=redis

# Redis URL (required when backend=redis)
BUILDER_REDIS_URL=redis://redis:6379/0

# Requests per minute per IP (default: 100)
# BUILDER_RATE_LIMIT=100

# ── Artifact Storage ────────────────────────────────────────────

# Backend: "local" (dev) or "s3" (production)
BUILDER_ARTIFACT_BACKEND=s3
BUILDER_S3_ENDPOINT_URL=
BUILDER_S3_BUCKET=
BUILDER_S3_REGION=
BUILDER_S3_ACCESS_KEY_ID=
BUILDER_S3_SECRET_ACCESS_KEY=

# ── Build Metadata ──────────────────────────────────────────────

GIT_COMMIT_SHA=
BUILD_TIME=

# ── FORBIDDEN in production ─────────────────────────────────────
#
# These patterns are rejected at startup:
# - NEXT_PUBLIC_BUILDER_API_TOKEN — browser must not hold raw API token
# - dev-token, test-token, changeme — known weak tokens
# - BUILDER_API_TOKEN < 32 chars — insufficient entropy
# - BUILDER_CORS_ORIGINS=* or empty — wildcard/missing CORS rejected
# - BUILDER_RATE_LIMIT_BACKEND=memory — not production-grade
