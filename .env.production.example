# Nautilus Builder — Production Environment Example
# Copy this file to .env.production and fill in real values.
# NEVER commit real secrets to version control.

# === REQUIRED ===
# Builder environment: production
BUILDER_ENV=production

# API authentication token (minimum 32 characters, NOT a dev/demo token)
BUILDER_API_TOKEN=change-me-to-a-secure-random-32-char-token

# CORS origins (comma-separated, no wildcards in production)
BUILDER_CORS_ORIGINS=https://your-builder-domain.example.com

# Redis URL for rate limiting (required in production)
BUILDER_REDIS_URL=redis://redis:6379/0

# === ARTIFACT STORAGE ===
# S3-compatible object storage for production artifacts
BUILDER_ARTIFACT_BACKEND=s3
BUILDER_ARTIFACT_ROOT=s3://your-bucket/artifacts

# === DATABASE (optional, defaults to in-memory) ===
# Builder-owned Postgres. Must NOT point to runtime/trading DBs.
BUILDER_PG_HOST=postgres
BUILDER_PG_PORT=5432
BUILDER_PG_DB=nautilus_builder
BUILDER_PG_USER=builder_app
BUILDER_PG_PASSWORD=change-me

# === FORBIDDEN IN PRODUCTION ===
# These values are rejected by config validation:
# - NEXT_PUBLIC_BUILDER_API_TOKEN (browser-exposed tokens forbidden)
# - exchange_secret, api_secret, private_key in config
# - Runtime/trading DB URLs detected in config
# - Static "change-me-in-production" tokens

# === OPTIONAL ===
# LLM provider for AI advisory drafts (optional)
# BUILDER_LLM_BASE_URL=https://api.openai.com/v1
# BUILDER_LLM_API_KEY=sk-...
# BUILDER_LLM_MODEL=gpt-4

# Build metadata (CI-injected)
# BUILDER_GIT_COMMIT=abc1234
# BUILDER_GIT_BRANCH=main
# BUILDER_BUILD_TIME_UTC=2026-06-11T12:00:00Z

# === VALIDATION ===
# The following tokens are FORBIDDEN in production:
# - dev-token or any known dev/demo token
# - change-me-in-production
# - NEXT_PUBLIC_BUILDER_API_TOKEN (browser-exposed)
